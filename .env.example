# ============================================
# Breitbandmessung - Konfiguration
# ============================================

# Zeitzone
# TZ=Europe/Berlin

# Cron-Schedule für Messungen
# CRON_SCHEDULE=0 */2 * * *

# Bei Container-Start sofort messen? (true/false)
# RUN_ON_STARTUP=true

# Nur einmal messen und beenden? (true/false)
# RUN_ONCE=false

# Screenshots speichern? (true/false)
# SAVE_SCREENSHOTS=true
