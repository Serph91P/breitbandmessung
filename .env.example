# ============================================
# Breitbandmessung - Konfiguration
# ============================================

# Pfad zur config.ini (Standard: ./config.ini aus dem Repo)
# Nur setzen wenn die Config woanders liegt, z.B. für
# persistente FritzBox-Zugangsdaten außerhalb des Repos
# CONFIG_PATH=/opt/breitbandmessung/config.ini

# Dashboard Port (Standard: 8501)
DASHBOARD_PORT=8501
